{
  "name": "glitch-cli",
  "version": "0.1.0",
  "description": "Glitch CLI for capture, pull, and MCP connector workflows",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryglitchapp/glitch.git",
    "directory": "glitch-cli"
  },
  "homepage": "https://github.com/tryglitchapp/glitch",
  "bugs": {
    "url": "https://github.com/tryglitchapp/glitch/issues"
  },
  "type": "module",
  "bin": {
    "glitch": "cli/dist/glitch.js"
  },
  "scripts": {
    "prepack": "npm run build",
    "build:cli-inject": "esbuild cli/capture-inject.ts --bundle --format=iife --outfile=cli/dist/capture-inject.js",
    "build:cli:entry": "esbuild cli/glitch.ts --bundle --platform=node --format=esm --packages=external --outfile=cli/dist/glitch.js",
    "build": "npm run build:cli-inject && npm run build:cli:entry",
    "test": "vitest run"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "playwright": "^1.57.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "cli/dist/glitch.js",
    "cli/dist/capture-inject.js"
  ],
  "license": "MIT"
}
